---
import { getCollection } from "astro:content";
import Icon from "./Icon.astro";

const [allPosts, allProjects] = await Promise.all([
  getCollection("blog"),
  getCollection("projects"),
]);

const posts = allPosts.toSorted(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const projects = allProjects.toSorted((a, b) => a.data.order - b.data.order);

interface Props {
  id?: string;
}

const { id }: Props = Astro.props;
const sidebarId = id ?? "docs-sidebar";

const pathname = Astro.url.pathname;
const projectsActive =
  pathname === "/projects" || pathname.startsWith("/projects/");
const blogActive = pathname === "/blog" || pathname.startsWith("/blog/");
const isItemActive = (href: string) =>
  pathname === href || pathname === `${href}/`;

const closeAttrs = {
  command: "close",
  commandfor: sidebarId,
} as const;
---

<dialog id={id} class="docs-sidebar" aria-label="Section navigation">
  <ul class="docs-sidebar__group">
    <li>
      <a
        href="/"
        {...closeAttrs}
        class:list={[
          "docs-sidebar__top-link",
          { "is-active": pathname === "/" },
        ]}
      >
        Home
      </a>
    </li>
    <li>
      <a
        href="/about"
        {...closeAttrs}
        class:list={[
          "docs-sidebar__top-link",
          { "is-active": isItemActive("/about") },
        ]}
      >
        About
      </a>
    </li>
  </ul>

  <ul class="docs-sidebar__group">
    <li>
      <details name="sidebar-sections" open={projectsActive}>
        <summary
          class:list={[
            "docs-sidebar__summary",
            { "is-active": pathname === "/projects" },
          ]}
        >
          <span class="docs-sidebar__chevron" aria-hidden="true">
            <Icon name="lucide:chevron-right" size={14} />
          </span>
          <span class="docs-sidebar__summary-link">Projects</span>
        </summary>
        <ul class="docs-sidebar__items">
          {
            projects.map((project) => {
              const href = `/projects/${project.id}`;
              return (
                <li>
                  <a
                    href={href}
                    {...closeAttrs}
                    class:list={[
                      "docs-sidebar__link",
                      { "is-active": isItemActive(href) },
                    ]}
                  >
                    {project.data.title}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </details>
    </li>
  </ul>

  <ul class="docs-sidebar__group">
    <li>
      <details name="sidebar-sections" open={blogActive}>
        <summary
          class:list={[
            "docs-sidebar__summary",
            { "is-active": pathname === "/blog" },
          ]}
        >
          <span class="docs-sidebar__chevron" aria-hidden="true">
            <Icon name="lucide:chevron-right" size={14} />
          </span>
          <span class="docs-sidebar__summary-link">Writing</span>
        </summary>
        <ul class="docs-sidebar__items">
          {
            posts.map((post) => {
              const href = `/blog/${post.id}`;
              return (
                <li>
                  <a
                    href={href}
                    {...closeAttrs}
                    class:list={[
                      "docs-sidebar__link",
                      { "is-active": isItemActive(href) },
                    ]}
                  >
                    {post.data.title}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </details>
    </li>
  </ul>
</dialog>
