---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import Tabs from "./Tabs.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { SOCIAL_LINKS } from "../consts";
---

<header class="site-header">
  <div class="site-header__bar">
    <div class="site-header__left">
      <button
        type="button"
        class="site-header__menu icon-button"
        command="show-modal"
        commandfor="site-drawer"
        aria-haspopup="dialog"
        aria-controls="site-drawer"
        aria-expanded="false"
        aria-label="Open navigation menu"
      >
        <Icon name="lucide:menu" size={20} aria-hidden="true" />
      </button>

      <a class="site-header__brand" href="/" transition:name="site-brand">
        <Logo />
      </a>
    </div>

    <div class="site-header__actions">
      <button
        type="button"
        class="search-trigger"
        data-search-trigger
        aria-label="Search"
        aria-keyshortcuts="Control+K Meta+K"
      >
        <Icon name="lucide:search" size={16} aria-hidden="true" />
        <span class="search-trigger__label">Search</span>
        <kbd class="search-trigger__kbd" data-kbd-mac><span class="search-trigger__cmd">⌘</span>K</kbd>
        <kbd class="search-trigger__kbd" data-kbd-ctrl>Ctrl K</kbd>
      </button>

      <ThemeToggle />

      <div class="site-header__social" aria-label="Social links">
        {
          SOCIAL_LINKS.map((link) => {
            const isExternal = link.href.startsWith("http");
            return (
              <a
                class="icon-button"
                href={link.href}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
                aria-label={link.label}
              >
                <Icon name={link.icon} size={18} aria-hidden="true" />
              </a>
            );
          })
        }
      </div>
    </div>
  </div>

  <div class="site-header__tabs">
    <Tabs variant="bar" />
  </div>
</header>
