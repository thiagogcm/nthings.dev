---
import Icon from './Icon.astro';
import { NAV_LINKS, SOCIAL_LINKS } from '../consts';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(`${href}/`));
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="site-header__brand" href="/" transition:name="site-brand">
      <span class="site-header__brand-mark">TM</span>
      <span>nthings.dev</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {NAV_LINKS.map((link) => {
        const active = isActive(link.href);

        return (
          <a
            href={link.href}
            aria-current={active ? 'page' : undefined}
            class:list={['site-header__nav-link', { 'is-active': active }]}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="site-header__social" aria-label="Social links">
      {SOCIAL_LINKS.map((link) => {
        const isExternal = link.href.startsWith('http');

        return (
          <a
            class="site-header__social-link"
            href={link.href}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
            aria-label={link.label}
          >
            <Icon name={link.icon} aria-hidden="true" />
          </a>
        );
      })}
    </div>
  </div>
</header>
