---
import { NAV_LINKS } from '../consts';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(`${href}/`));
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/">
      <span class="brand__mark">TM</span>
      <span class="brand__text">
        <span class="brand__name">Thiago Moura</span>
        <span class="brand__meta">nthings.dev</span>
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="site-nav">
        {NAV_LINKS.map((link) => {
          const active = isActive(link.href);
          let iconSvg = '';
          if (link.label === 'Blog') {
            iconSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>';
          } else if (link.label === 'Projects') {
            iconSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>';
          } else {
            iconSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>';
          }

          return (
            <li>
              <a
                href={link.href}
                aria-current={active ? 'page' : undefined}
                class:list={['site-nav__link', { 'is-active': active }]}
              >
                <Fragment set:html={iconSvg} />
                <span>{link.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav__link {
    gap: 0.75rem;
  }
</style>
