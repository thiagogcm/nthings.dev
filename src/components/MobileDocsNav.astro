---
import type { MarkdownHeading } from "astro";
import Icon from "./Icon.astro";
import type { ProjectNavItem } from "../lib/collections";
import { isNavItemActive, tocHeadings } from "../lib/nav";

interface Props {
  headings?: MarkdownHeading[];
  pageNav?: ProjectNavItem[];
}

const { headings = [], pageNav = [] } = Astro.props;
const toc = tocHeadings(headings);
const pathname = Astro.url.pathname;
const hasPageNav = pageNav.length > 1;
const hasToc = toc.length > 0;
---

{
  (hasPageNav || hasToc) && (
    <aside class="mobile-doc-nav" aria-label="Document navigation">
      {hasPageNav && (
        <details class="mobile-doc-nav__details">
          <summary class="mobile-doc-nav__summary">
            <span class="mobile-doc-nav__summary-label">
              <Icon name="lucide:folder-kanban" size={16} aria-hidden="true" />
              <span>Docs</span>
            </span>
            <Icon
              name="lucide:chevron-right"
              size={16}
              class="mobile-doc-nav__chevron"
              aria-hidden="true"
            />
          </summary>

          <div class="mobile-doc-nav__body">
            <nav aria-label="Project docs">
              <ul class="mobile-doc-nav__page-list">
                {pageNav.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        "mobile-doc-nav__page-link",
                        {
                          "is-active": isNavItemActive(
                            pathname,
                            item.href,
                            item.isOverview,
                          ),
                        },
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </details>
      )}

      {hasToc && (
        <details class="mobile-doc-nav__details">
          <summary class="mobile-doc-nav__summary">
            <span class="mobile-doc-nav__summary-label">
              <Icon name="lucide:notebook-tabs" size={16} aria-hidden="true" />
              <span>On this page</span>
            </span>
            <Icon
              name="lucide:chevron-right"
              size={16}
              class="mobile-doc-nav__chevron"
              aria-hidden="true"
            />
          </summary>

          <div class="mobile-doc-nav__body">
            <nav aria-label="On this page">
              <ul class="mobile-doc-nav__toc">
                {toc.map((heading) => (
                  <li class={`mobile-doc-nav__toc-item depth-${heading.depth}`}>
                    <a
                      href={`#${heading.slug}`}
                      class="mobile-doc-nav__toc-link"
                      data-toc-link={heading.slug}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </details>
      )}
    </aside>
  )
}

<script>
  (function () {
    if ((window as any).__nthingsMobileDocsNav) {
      return;
    }
    (window as any).__nthingsMobileDocsNav = true;

    // `toggle` doesn't bubble, so listen in the capture phase.
    let openPanel: HTMLDetailsElement | null = null;
    let openedAtY = 0;
    document.addEventListener(
      "toggle",
      (event) => {
        const details = event.target;
        if (
          details instanceof HTMLDetailsElement &&
          details.closest(".mobile-doc-nav")
        ) {
          openPanel = details.open ? details : null;
          openedAtY = window.scrollY;
        }
      },
      true,
    );

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!openPanel || !(target instanceof Element)) {
        return;
      }
      if (target.closest(".mobile-doc-nav a") || !openPanel.contains(target)) {
        openPanel.open = false;
      }
    });

    // The open panel is sticky and covers content; close it once the page
    // scrolls away beneath it.
    window.addEventListener(
      "scroll",
      () => {
        if (openPanel && Math.abs(window.scrollY - openedAtY) > 24) {
          openPanel.open = false;
        }
      },
      { passive: true },
    );
  })();
</script>
