---
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const projectHref = `/projects/${project.id}`;
---

<article class="content-card">
  <div class="card-kicker">
    <span class="card-label">Selected build</span>
    {project.data.website && (
      <a href={project.data.website} target="_blank" rel="noopener noreferrer" class="card-link card-link--muted">
        <span>Live site</span>
        <Icon name="lucide:arrow-up-right" aria-hidden="true" />
      </a>
    )}
  </div>

  <div class="card-copy">
    <h3 class="card-title" transition:name={`project-title-${project.id}`}>
      <a href={projectHref}>
        {project.data.title}
      </a>
    </h3>
    <p>{project.data.description}</p>
  </div>

  {project.data.tags && project.data.tags.length > 0 && (
    <ul class="tag-list">
      {project.data.tags.map((tag) => <li class="tag">{tag}</li>)}
    </ul>
  )}

  <div class="card-actions">
    <a href={projectHref} class="button">
      <span>Case study</span>
      <Icon name="lucide:arrow-right" aria-hidden="true" />
    </a>
    {project.data.repository && (
      <a href={project.data.repository} target="_blank" rel="noopener noreferrer" class="button--ghost">
        <span>Source</span>
        <Icon name="lucide:arrow-up-right" aria-hidden="true" />
      </a>
    )}
  </div>
</article>
