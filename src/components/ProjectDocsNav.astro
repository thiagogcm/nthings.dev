---
import type { ProjectNavItem } from "@/lib/collections";
import { isActive } from "@/lib/nav";

interface Props {
  items: ProjectNavItem[];
}

const { items } = Astro.props;
const pathname = Astro.url.pathname;
---

{
  items.length > 1 && (
    <aside class="project-docs-nav" aria-label="Project docs">
      <p class="project-docs-nav__heading">Docs</p>
      <nav aria-label="Project docs">
        <ul class="project-docs-nav__list">
          {items.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "project-docs-nav__link",
                  {
                    "is-active": isActive(pathname, item.href, item.isOverview),
                  },
                ]}
                aria-current={
                  isActive(pathname, item.href, item.isOverview)
                    ? "page"
                    : undefined
                }
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}
