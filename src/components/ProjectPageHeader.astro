---
import Icon from "./Icon.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  pageTitle?: string;
  pageDescription?: string;
}

const { project, pageTitle, pageDescription } = Astro.props;
const heading = pageTitle ?? project.data.title;
const lede =
  pageDescription ?? (pageTitle ? undefined : project.data.description);
---

<header class="grid gap-[0.85rem] pb-8 border-b border-border">
  <a
    class="text-link text-link--muted w-fit mb-2 text-[0.85rem]"
    href="/projects"
  >
    <Icon name="lucide:arrow-right" class="rotate-180" aria-hidden="true" />
    <span>Projects</span>
  </a>

  {
    pageTitle && (
      <a
        class="text-link text-link--muted w-fit text-[0.85rem]"
        href={`/projects/${project.id}`}
      >
        <span>{project.data.title}</span>
      </a>
    )
  }

  <p class="eyebrow">{pageTitle ? "Documentation" : "Project"}</p>
  <h1>{heading}</h1>
  {lede && <p class="lede">{lede}</p>}

  {
    !pageTitle && (
      <>
        <div class="flex flex-wrap gap-x-6 gap-y-2 mt-2">
          {project.data.website && (
            <a
              class="text-link"
              href={project.data.website}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Live site</span>
              <Icon name="lucide:arrow-up-right" aria-hidden="true" />
            </a>
          )}
          {project.data.repository && (
            <a
              class="text-link"
              href={project.data.repository}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Source code</span>
              <Icon name="lucide:arrow-up-right" aria-hidden="true" />
            </a>
          )}
        </div>

        {project.data.tags && project.data.tags.length > 0 && (
          <ul class="tag-list">
            {project.data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )}
      </>
    )
  }
</header>
