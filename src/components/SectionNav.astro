---
import Icon from "./Icon.astro";
import SectionLinks from "./SectionLinks.astro";
import { getSortedPosts, getSortedProjects } from "../lib/collections";
import { isActive } from "../lib/nav";

interface Props {
  closeFor?: string;
}

const { closeFor }: Props = Astro.props;

const [posts, projects] = await Promise.all([
  getSortedPosts(),
  getSortedProjects(),
]);

const pathname = Astro.url.pathname;
const closeAttrs = closeFor ? { command: "close", commandfor: closeFor } : {};

const allSections = [
  {
    key: "projects",
    label: "Projects",
    href: "/projects",
    items: projects.map((p) => ({ href: `/projects/${p.id}`, title: p.data.title })),
  },
  {
    key: "blog",
    label: "Blog",
    href: "/blog",
    items: posts.map((p) => ({ href: `/blog/${p.id}`, title: p.data.title })),
  },
] as const;

// Inside a section, drop the redundant parent and show a flat list; elsewhere
// (home/about) keep grouped, collapsible sections so the labels tell them apart.
const currentSection =
  allSections.find((section) => isActive(pathname, section.href)) ?? null;
---

{
  currentSection ? (
    <nav class="section-nav" aria-label={currentSection.label}>
      <SectionLinks items={currentSection.items} flat closeFor={closeFor} />
    </nav>
  ) : (
    <nav class="section-nav" aria-label="Sections">
      {allSections.map((section) => (
        <details
          class="section-nav__group"
          open={isActive(pathname, section.href)}
        >
          <summary
            class:list={[
              "section-nav__summary",
              { "is-active": isActive(pathname, section.href, true) },
            ]}
          >
            <span class="section-nav__chevron" aria-hidden="true">
              <Icon name="lucide:chevron-right" size={14} />
            </span>
            <a href={section.href} class="section-nav__summary-link" {...closeAttrs}>
              {section.label}
            </a>
          </summary>
          {section.items.length > 0 && (
            <SectionLinks items={section.items} closeFor={closeFor} />
          )}
        </details>
      ))}
    </nav>
  )
}
