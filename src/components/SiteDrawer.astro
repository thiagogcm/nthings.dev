---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import Tabs from "./Tabs.astro";

const drawerId = "site-drawer";
const closeAttrs = { command: "close", commandfor: drawerId } as const;
---

<dialog id={drawerId} class="site-drawer" aria-label="Navigation">
  <div class="site-drawer__panel">
    <div class="site-drawer__head">
      <a class="site-drawer__brand" href="/" {...closeAttrs}>
        <Logo />
      </a>
      <button
        type="button"
        class="icon-button"
        {...closeAttrs}
        aria-label="Close navigation menu"
      >
        <Icon name="lucide:x" size={20} aria-hidden="true" />
      </button>
    </div>

    <Tabs variant="drawer" closeFor={drawerId} />
  </div>
</dialog>
