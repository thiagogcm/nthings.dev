---
import { env } from "cloudflare:workers";
import { getGitHubStats, refreshGitHubStats } from "../lib/github-stats";
import { formatDate } from "../lib/format-date";

// On a cold cache, kick off a non-blocking refresh so the next render is populated.
const stats = await getGitHubStats(env);
if (!stats) {
  Astro.locals.cfContext?.waitUntil(
    refreshGitHubStats(env).catch(() => undefined),
  );
}

const numberFormatter = new Intl.NumberFormat("en-US");

const row = "flex items-center gap-1.5";
const dot = "size-1.5 rounded-full";
---

<div class="status-widget">
  {
    stats ? (
      <>
        <div class={row}>
          <span class={`${dot} bg-ok animate-[status-pulse_2s_infinite]`} />
          <span class="text-fg-soft font-medium">GitHub:</span>
          <span class="text-fg">{stats.repoCount} repos</span>
        </div>
        <div class={row}>
          <span class={`${dot} bg-ok`} />
          <span class="text-fg-soft font-medium">Commits:</span>
          <span class="text-fg">
            {numberFormatter.format(stats.commitCount)}
          </span>
        </div>
        <div class={`${row} status-widget__detail`}>
          <span class={`${dot} bg-accent`} />
          <span class="text-fg-soft font-medium">Last update:</span>
          <span class="text-fg">{formatDate(new Date(stats.lastUpdate))}</span>
        </div>
      </>
    ) : (
      <div class={row}>
        <span
          class={`${dot} bg-border-strong animate-[status-fade_1.5s_infinite_ease-in-out]`}
        />
        <span class="text-fg-soft font-medium">GitHub:</span>
        <span class="text-fg-soft animate-[status-fade_1.5s_infinite_ease-in-out]">
          syncing stats...
        </span>
      </div>
    )
  }
</div>
