---
import { env } from "cloudflare:workers";
import {
  ACTIVITY_DAYS,
  activityMetricQuery,
  getGitHubStats,
  refreshGitHubStats,
} from "../lib/github-stats";
import MetricPanel from "./MetricPanel.astro";

const stats = await getGitHubStats(env);
// Entries cached before the activity chart shipped lack `dailyActivity`; treat a
// missing/empty series as a cold cache and kick a non-blocking refresh.
const hasChart =
  !!stats && Array.isArray(stats.dailyActivity) && stats.dailyActivity.length > 0;

if (!hasChart) {
  Astro.locals.cfContext?.waitUntil(
    refreshGitHubStats(env).catch(() => undefined),
  );
}

const promql = activityMetricQuery(env.GITHUB_USERNAME);
---

{
  hasChart && stats ? (
    <MetricPanel stats={stats} username={env.GITHUB_USERNAME} />
  ) : (
    <div class="metric-panel border-dashed opacity-70">
      <div class="metric-panel__header">
        <span class="metric-panel__query">{promql}</span>
        <span class="metric-panel__range">last {ACTIVITY_DAYS}d</span>
      </div>
      <div class="metric-panel__chart metric-panel__chart--empty">
        <span class="size-1.5 rounded-full bg-border-strong animate-[status-fade_1.5s_infinite_ease-in-out]" />
        <span class="text-fg-soft animate-[status-fade_1.5s_infinite_ease-in-out]">
          syncing activity…
        </span>
      </div>
    </div>
  )
}
