---
// This will render dynamically on the server at request time!
const timestamp = new Date();
const timeString = timestamp.toLocaleTimeString('en-US', {
  timeZone: 'America/Sao_Paulo',
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
});
const dateString = timestamp.toLocaleDateString('en-US', {
  timeZone: 'America/Sao_Paulo',
  month: 'short',
  day: 'numeric',
});

// A dynamic simulation of server performance & checks for the "Observability" theme
const randomLatency = Math.floor(Math.random() * 8) + 8; // 8-15ms

const row = 'flex items-center gap-1.5';
const dot = 'size-1.5 rounded-full';
---

<div class="status-widget">
  <div class={row}>
    <span class={`${dot} bg-ok animate-[status-pulse_2s_infinite]`}></span>
    <span class="text-fg-soft font-medium">Belo Horizonte, BR:</span>
    <span class="text-fg">{dateString}, {timeString} BRT</span>
  </div>
  <div class={row}>
    <span class={`${dot} bg-ok`}></span>
    <span class="text-fg-soft font-medium">System status:</span>
    <span class="text-fg">Active & select collab open</span>
  </div>
  <div class={`${row} max-[48rem]:hidden`}>
    <span class={`${dot} bg-accent`}></span>
    <span class="text-fg-soft font-medium">Observability:</span>
    <span class="text-fg">Latency {randomLatency}ms · SSR Active</span>
  </div>
</div>
