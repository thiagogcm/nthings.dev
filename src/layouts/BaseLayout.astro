---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter, slide } from "astro:transitions";
import Header from "../components/Header.astro";
import { SITE, SOCIAL_LINKS } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
} = Astro.props;
const siteUrl = Astro.site ?? new URL(SITE.url);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const socialImage = new URL(image, siteUrl);
const pageTitle = title
  ? title === SITE.title
    ? title
    : `${title} | ${SITE.title}`
  : SITE.title;
const isArticle = Astro.url.pathname.startsWith("/blog/");

const dnsPrefetchHosts = [
  ...new Set(
    SOCIAL_LINKS.map((link) => link.href)
      .filter((href) => href.startsWith("http"))
      .map((href) => new URL(href).hostname),
  ),
];
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="theme-color"
      content="#fcfcfd"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0a0b0d"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="color-scheme" content="light dark" />

    {
      dnsPrefetchHosts.map((host) => (
        <link rel="dns-prefetch" href={`https://${host}`} />
      ))
    }

    <link rel="canonical" href={canonicalUrl.toString()} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.title} RSS Feed`}
      href={new URL("/rss.xml", siteUrl).toString()}
    />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={socialImage.toString()} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImage.toString()} />
    <title>{pageTitle}</title>
    <!-- Astro <Font> has no fetchpriority API; narrow preloads to normal style only. -->
    <Font
      cssVariable="--font-body"
      preload={[
        { weight: 400, style: "normal" },
        { weight: 600, style: "normal" },
      ]}
    />
    <Font
      cssVariable="--font-code"
      preload={[{ weight: 400, style: "normal" }]}
    />
    <ClientRouter />
  </head>
  <body>
    <a
      class="absolute left-4 -top-16 z-20 px-4 py-3 border border-border rounded-md bg-bg transition-[top] duration-150 focus:top-4"
      href="#main-content">Skip to content</a
    >
    <div class="flex flex-col min-h-screen">
      <Header />

      <main
        id="main-content"
        class="flex-1 min-w-0 py-[clamp(2.5rem,5vw,4rem)]"
        transition:name="page-shell"
        transition:animate={slide({ duration: "0.32s" })}
      >
        <div class="shell">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // Sync drawer toggle aria-expanded after view-transition swaps.
      (function () {
        if ((window as any).__nthingsUIBound) return;
        (window as any).__nthingsUIBound = true;

        const bindSidebar = () => {
          const dialog = document.getElementById(
            "docs-sidebar",
          ) as HTMLDialogElement | null;
          const toggle = document.querySelector(
            '[commandfor="docs-sidebar"]',
          ) as HTMLButtonElement | null;
          if (!dialog || !toggle || (dialog as any).__sidebarBound) return;
          (dialog as any).__sidebarBound = true;

          dialog.addEventListener("toggle", (e) => {
            const { newState } = e as ToggleEvent;
            toggle.setAttribute("aria-expanded", String(newState === "open"));
          });
        };

        const refresh = () => bindSidebar();
        document.addEventListener("astro:page-load", refresh);
        document.addEventListener("astro:after-swap", refresh);
        refresh();
      })();
    </script>
  </body>
</html>
