---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter, slide } from 'astro:transitions';
import Header from '../components/Header.astro';
import Icon from '../components/Icon.astro';
import { SITE, SOCIAL_LINKS } from '../consts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description = SITE.description, image = SITE.ogImage } = Astro.props;
const siteUrl = Astro.site ?? new URL(SITE.url);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const socialImage = new URL(image, siteUrl);
const pageTitle = title ? (title === SITE.title ? title : `${title} | ${SITE.title}`) : SITE.title;
const isArticle = Astro.url.pathname.startsWith('/blog/');
const currentYear = new Date().getUTCFullYear();
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f5" />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.title} RSS Feed`}
      href={new URL('/rss.xml', siteUrl).toString()}
    />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={socialImage.toString()} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImage.toString()} />
    <title>{pageTitle}</title>
    <Font cssVariable="--font-body" preload={[{ weight: 400 }, { weight: 600 }]} />
    <Font cssVariable="--font-display" preload={[{ weight: 600 }]} />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="site-shell">
      <Header />

      <main
        id="main-content"
        class="site-main"
        transition:name="page-shell"
        transition:animate={slide({ duration: '0.32s' })}
      >
        <div class="shell">
          <slot />
        </div>
      </main>

      <footer class="site-footer">
        <div class="shell site-footer__inner">
          <div class="site-footer__copy">
            <span>© {currentYear} {SITE.author}</span>
            <span>·</span>
            <span>{SITE.location}</span>
          </div>

          <div class="site-footer__links">
            {SOCIAL_LINKS.map((link) => {
              const isExternal = link.href.startsWith('http');

              return (
                <a
                  class="site-footer__link"
                  href={link.href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                >
                  <Icon name={link.icon} aria-hidden="true" />
                  <span>{link.label}</span>
                </a>
              );
            })}
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
