---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter, fade } from "astro:transitions";
import Header from "../components/Header.astro";
import SiteDrawer from "../components/SiteDrawer.astro";
import SearchModal from "../components/SearchModal.astro";
import { SITE, SOCIAL_LINKS } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Wrap the slot in the centered reading container (home / about). */
  contained?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
  contained = false,
} = Astro.props;
const siteUrl = Astro.site ?? new URL(SITE.url);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const socialImage = new URL(image, siteUrl);
const pageTitle = title
  ? title === SITE.title
    ? title
    : `${title} | ${SITE.title}`
  : SITE.title;
const isArticle = Astro.url.pathname.startsWith("/blog/");

const dnsPrefetchHosts = [
  ...new Set(
    SOCIAL_LINKS.map((link) => link.href)
      .filter((href) => href.startsWith("http"))
      .map((href) => new URL(href).hostname),
  ),
];
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="theme-color"
      content="#fcfcfd"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0a0b0d"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="color-scheme" content="light dark" />

    <!-- No-flash theme: apply the saved preference before first paint, and
         re-apply after each view-transition swap (which resets <html> attrs). -->
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem("theme");
            if (t === "light" || t === "dark") {
              document.documentElement.dataset.theme = t;
            } else {
              delete document.documentElement.dataset.theme;
            }
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>

    {
      dnsPrefetchHosts.map((host) => (
        <link rel="dns-prefetch" href={`https://${host}`} />
      ))
    }

    <link rel="canonical" href={canonicalUrl.toString()} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.title} RSS Feed`}
      href={new URL("/rss.xml", siteUrl).toString()}
    />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={socialImage.toString()} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImage.toString()} />
    <title>{pageTitle}</title>
    <!-- Astro <Font> has no fetchpriority API; narrow preloads to normal style only. -->
    <Font
      cssVariable="--font-body"
      preload={[
        { weight: 400, style: "normal" },
        { weight: 600, style: "normal" },
      ]}
    />
    <Font
      cssVariable="--font-code"
      preload={[{ weight: 400, style: "normal" }]}
    />
    <ClientRouter />
  </head>
  <body>
    <a
      class="skip-link"
      href="#main-content">Skip to content</a
    >

    <Header />
    <SiteDrawer />
    <SearchModal />

    <main
      id="main-content"
      class="site-main"
      transition:name="page-shell"
      transition:animate={fade({ duration: "0.22s" })}
    >
      {
        contained ? (
          <div class="shell">
            <slot />
          </div>
        ) : (
          <slot />
        )
      }
    </main>

    <script>
      // Keep invoker toggle aria-expanded in sync after view-transition swaps.
      (function () {
        if ((window as any).__nthingsDrawerBound) return;
        (window as any).__nthingsDrawerBound = true;

        const sync = () => {
          const dialog = document.getElementById(
            "site-drawer",
          ) as HTMLDialogElement | null;
          const toggle = document.querySelector(
            '[commandfor="site-drawer"][command="show-modal"]',
          ) as HTMLButtonElement | null;
          if (!dialog || !toggle || (dialog as any).__bound) return;
          (dialog as any).__bound = true;
          dialog.addEventListener("toggle", (e) => {
            const { newState } = e as ToggleEvent;
            toggle.setAttribute("aria-expanded", String(newState === "open"));
          });
        };

        document.addEventListener("astro:page-load", sync);
        document.addEventListener("astro:after-swap", sync);
        sync();
      })();

      // Lift the sticky header (shadow + solidified bg) once the page scrolls.
      (function () {
        if ((window as any).__nthingsScrollBound) return;
        (window as any).__nthingsScrollBound = true;

        let ticking = false;
        const apply = () => {
          ticking = false;
          document.documentElement.toggleAttribute(
            "data-scrolled",
            window.scrollY > 4,
          );
        };
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(apply);
        };

        window.addEventListener("scroll", onScroll, { passive: true });
        document.addEventListener("astro:page-load", apply);
        document.addEventListener("astro:after-swap", apply);
        apply();
      })();
    </script>
  </body>
</html>
