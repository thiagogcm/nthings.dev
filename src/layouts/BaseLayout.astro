---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter, slide } from "astro:transitions";
import Header from "../components/Header.astro";
import { SITE } from "../consts";
import { UI_INIT_SCRIPT } from "../lib/theme-init";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
} = Astro.props;
const siteUrl = Astro.site ?? new URL(SITE.url);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const socialImage = new URL(image, siteUrl);
const pageTitle = title
  ? title === SITE.title
    ? title
    : `${title} | ${SITE.title}`
  : SITE.title;
const isArticle = Astro.url.pathname.startsWith("/blog/");
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <!-- Single (non-media) theme-color; the init script syncs it to the resolved theme. -->
    <meta name="theme-color" content="#fcfcfd" />
    <meta name="color-scheme" content="light dark" />
    <!-- Anti-FOUC theme init (only is:inline script; CSP-hashed in astro.config.mjs). -->
    <script is:inline set:html={UI_INIT_SCRIPT} />

    <link rel="canonical" href={canonicalUrl.toString()} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.title} RSS Feed`}
      href={new URL("/rss.xml", siteUrl).toString()}
    />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={socialImage.toString()} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImage.toString()} />
    <title>{pageTitle}</title>
    <Font
      cssVariable="--font-body"
      preload={[{ weight: 400 }, { weight: 600 }]}
    />
    <Font cssVariable="--font-code" preload={[{ weight: 400 }]} />
    <ClientRouter />
  </head>
  <body>
    <a
      class="absolute left-4 -top-16 z-20 px-4 py-3 border border-border rounded-md bg-bg transition-[top] duration-150 focus:top-4"
      href="#main-content">Skip to content</a
    >
    <div class="flex flex-col min-h-screen">
      <Header />

      <main
        id="main-content"
        class="flex-1 min-w-0 py-[clamp(2.5rem,5vw,4rem)]"
        transition:name="page-shell"
        transition:animate={slide({ duration: "0.32s" })}
      >
        <div class="shell">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // Interactive UI wiring. Processed (not is:inline) so Astro hashes it for CSP, and
      // delegated on `document` so it survives view-transition swaps.
      (function () {
        if ((window as any).__nthingsUIBound) return;
        (window as any).__nthingsUIBound = true;
        const root = document.documentElement;

        const isDark = () => {
          const t = root.getAttribute("data-theme");
          return t
            ? t === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches;
        };

        const syncControls = () => {
          const themeBtn = document.querySelector("[data-theme-toggle]");
          if (themeBtn) themeBtn.setAttribute("aria-pressed", String(isDark()));
        };

        const bindSidebar = () => {
          const dialog = document.getElementById(
            "docs-sidebar",
          ) as HTMLDialogElement | null;
          const toggle = document.querySelector(
            '[commandfor="docs-sidebar"]',
          ) as HTMLButtonElement | null;
          if (!dialog || !toggle || (dialog as any).__sidebarBound) return;
          (dialog as any).__sidebarBound = true;

          dialog.addEventListener("toggle", (e) => {
            const { newState } = e as ToggleEvent;
            toggle.setAttribute("aria-expanded", String(newState === "open"));
          });

          // Light-dismiss: backdrop clicks target the dialog outside the panel.
          dialog.addEventListener("click", (e) => {
            if (e.target !== dialog) return;
            const r = dialog.getBoundingClientRect();
            const outside =
              e.clientX < r.left ||
              e.clientX > r.right ||
              e.clientY < r.top ||
              e.clientY > r.bottom;
            if (!outside) return;
            dialog.requestClose();
          });
        };

        document.addEventListener("click", (e) => {
          const target = e.target as Element | null;
          if (!target?.closest) return;

          if (target.closest("[data-theme-toggle]")) {
            const next = isDark() ? "light" : "dark";
            root.setAttribute("data-theme", next);
            try {
              localStorage.setItem("theme", next);
            } catch {}
            (window as any).__themeSyncMeta?.();
            syncControls();
            return;
          }

          const dialog = document.getElementById(
            "docs-sidebar",
          ) as HTMLDialogElement | null;
          if (dialog?.open && target.closest(".docs-sidebar a")) {
            dialog.requestClose();
          }
        });

        const onScroll = () => {
          if (window.scrollY > 4) root.setAttribute("data-scrolled", "");
          else root.removeAttribute("data-scrolled");
        };
        window.addEventListener("scroll", onScroll, { passive: true });

        const refresh = () => {
          syncControls();
          bindSidebar();
          onScroll();
        };
        document.addEventListener("astro:page-load", refresh);
        document.addEventListener("astro:after-swap", refresh);
        refresh();
      })();
    </script>
  </body>
</html>
