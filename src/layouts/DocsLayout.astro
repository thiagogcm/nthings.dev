---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Icon from '../components/Icon.astro';
import type { MarkdownHeading } from 'astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  headings?: MarkdownHeading[];
  showToc?: boolean;
}

const { title, description, image, headings = [], showToc = false } = Astro.props;
const withToc = showToc && headings.length > 0;
---

<BaseLayout title={title} description={description} image={image}>
  <div class:list={['docs-grid', { 'docs-grid--with-toc': withToc }]}>
    <details class="docs-sidebar__drawer">
      <summary>Sections</summary>
      <DocsSidebar />
    </details>

    <DocsSidebar id="docs-sidebar" />

    <div class="docs-main">
      <div class="docs-toolbar">
        <button
          type="button"
          class="sidebar-toggle"
          data-sidebar-toggle
          aria-controls="docs-sidebar"
          aria-expanded="true"
          aria-label="Collapse sidebar"
        >
          <Icon
            name="lucide:panel-left-close"
            size={18}
            class="sidebar-toggle__icon sidebar-toggle__icon--close"
            aria-hidden="true"
          />
          <Icon
            name="lucide:panel-left-open"
            size={18}
            class="sidebar-toggle__icon sidebar-toggle__icon--open"
            aria-hidden="true"
          />
        </button>
      </div>

      <slot />
    </div>

    {withToc && <TableOfContents headings={headings} />}
  </div>
</BaseLayout>
