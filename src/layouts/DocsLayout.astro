---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import Icon from "../components/Icon.astro";
import type { MarkdownHeading } from "astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  headings?: MarkdownHeading[];
  showToc?: boolean;
}

const {
  title,
  description,
  image,
  headings = [],
  showToc = false,
} = Astro.props;
const withToc = showToc && headings.length > 0;
---

<BaseLayout title={title} description={description} image={image}>
  <div class:list={["docs-grid", { "docs-grid--with-toc": withToc }]}>
    <DocsSidebar id="docs-sidebar" />

    <div class="docs-main">
      <div class="docs-toolbar">
        <button
          type="button"
          class="sidebar-mobile-toggle"
          data-mobile-sidebar-toggle
          aria-haspopup="dialog"
          aria-controls="docs-sidebar"
          aria-expanded="false"
          aria-label="Open navigation menu"
        >
          <Icon name="lucide:menu" size={18} aria-hidden="true" />
          <span>Sections</span>
        </button>
      </div>

      <slot />
    </div>

    {withToc && <TableOfContents headings={headings} />}
  </div>
</BaseLayout>
