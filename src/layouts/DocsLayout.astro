---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { tocHeadings } from "../lib/nav";
import type { MarkdownHeading } from "astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  headings?: MarkdownHeading[];
  showToc?: boolean;
}

const {
  title,
  description,
  image,
  headings = [],
  showToc = false,
} = Astro.props;
const withToc = showToc && tocHeadings(headings).length > 0;
---

<BaseLayout title={title} description={description} image={image}>
  <div class:list={["docs-layout", { "docs-layout--with-toc": withToc }]}>
    <DocsSidebar />

    <div class="docs-content">
      <slot />
    </div>

    {withToc && <TableOfContents headings={headings} />}
  </div>
</BaseLayout>
