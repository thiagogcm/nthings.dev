---
import type { MarkdownHeading } from "astro";
import MermaidDiagrams from "@/components/MermaidDiagrams.astro";
import MobileDocsNav from "@/components/MobileDocsNav.astro";
import ProjectDocsNav from "@/components/ProjectDocsNav.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { ProjectNavItem } from "@/lib/collections";
import { tocHeadings } from "@/lib/nav";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  headings?: MarkdownHeading[];
  showToc?: boolean;
  pageNav?: ProjectNavItem[];
}

const {
  title,
  description,
  image,
  headings = [],
  showToc = false,
  pageNav = [],
} = Astro.props;
const withToc = showToc && tocHeadings(headings).length > 0;
const withPageNav = pageNav.length > 1;
---

<BaseLayout title={title} description={description} image={image}>
  <div
    class:list={[
      "docs-layout",
      {
        "docs-layout--with-toc": withToc,
        "docs-layout--with-nav": withPageNav,
      },
    ]}
  >
    <MobileDocsNav
      headings={withToc ? headings : []}
      pageNav={withPageNav ? pageNav : []}
    />

    {withPageNav && <ProjectDocsNav items={pageNav} />}

    <div class="docs-content">
      <slot />
    </div>

    {withToc && <TableOfContents headings={headings} />}
  </div>
</BaseLayout>

<MermaidDiagrams />

<script>
  import "@/scripts/heading-permalinks";
</script>
