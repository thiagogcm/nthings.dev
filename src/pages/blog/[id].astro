---
import Icon from "../../components/Icon.astro";
import { getCollection, render } from "astro:content";
import { formatDate } from "../../lib/format-date";
import DocsLayout from "../../layouts/DocsLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<DocsLayout
  title={post.data.title}
  description={post.data.description}
  headings={headings}
  showToc={true}
>
  <article class="doc">
    <header class="doc__header">
      <a class="text-link text-link--muted doc__back" href="/blog">
        <Icon name="lucide:arrow-right" aria-hidden="true" />
        <span>Writing</span>
      </a>

      <p class="eyebrow">Writing</p>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>

      <div class="doc__meta">
        <span>Published {formatDate(post.data.pubDate)}</span>
        {
          post.data.updatedDate && (
            <>
              <span>·</span>
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            </>
          )
        }
      </div>

      {
        post.data.tags && post.data.tags.length > 0 && (
          <ul class="tag-list">
            {post.data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>

<style>
  .doc {
    display: grid;
    gap: 2.5rem;
  }

  .doc__header {
    display: grid;
    gap: 0.85rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .doc__back {
    width: fit-content;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
  }

  .doc__back :global(svg) {
    transform: rotate(180deg);
  }

  .doc__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-soft);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
</style>
