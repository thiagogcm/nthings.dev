---
import Icon from "../../components/Icon.astro";
import { getCollection, render } from "astro:content";
import { formatDate } from "../../lib/format-date";
import DocsLayout from "../../layouts/DocsLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<DocsLayout
  title={post.data.title}
  description={post.data.description}
  headings={headings}
  showToc={true}
>
  <article class="grid grid-cols-[minmax(0,1fr)] gap-10">
    <header class="grid gap-[0.85rem]">
      <a
        class="text-link text-link--muted w-fit mb-2 text-[0.85rem]"
        href="/blog"
      >
        <Icon name="lucide:arrow-right" class="rotate-180" aria-hidden="true" />
        <span>Blog</span>
      </a>

      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>

      <div class="flex flex-wrap gap-2 text-fg-soft font-mono text-[0.82rem]">
        <span>Published {formatDate(post.data.pubDate)}</span>
        {
          post.data.updatedDate && (
            <>
              <span>·</span>
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            </>
          )
        }
      </div>

      {
        post.data.tags && post.data.tags.length > 0 && (
          <ul class="tag-list">
            {post.data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>
