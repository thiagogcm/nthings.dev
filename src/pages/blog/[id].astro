---
import Icon from '../../components/Icon.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../lib/format-date';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<DocsLayout
  title={post.data.title}
  description={post.data.description}
  headings={headings}
  showToc={true}
>
  <article class="post fade-sequence">
    <header class="post__header">
      <a class="section-link post__back" href="/blog">
        <Icon name="lucide:arrow-right" aria-hidden="true" />
        <span>Back to the blog</span>
      </a>

      <p class="eyebrow">Blog</p>
      <h1 transition:name={`post-title-${post.id}`}>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>

      <div class="post__meta">
        <span>Published {formatDate(post.data.pubDate)}</span>
        {post.data.updatedDate && (
          <>
            <span>·</span>
            <span>Updated {formatDate(post.data.updatedDate)}</span>
          </>
        )}
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <ul class="tag-list">
          {post.data.tags.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>

<style>
  .post {
    display: grid;
    gap: 2rem;
  }

  .post__header {
    display: grid;
    gap: 0.75rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .post__back {
    width: fit-content;
    color: var(--text-soft);
  }

  .post__back :global(svg) {
    transform: rotate(180deg);
  }

  .post__back:hover,
  .post__back:focus-visible {
    color: var(--accent);
  }

  .post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-soft);
    font-size: 0.88rem;
  }
</style>
