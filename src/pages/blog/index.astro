---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import DocsLayout from '../../layouts/DocsLayout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<DocsLayout
  title="Blog"
  description="Notes on software engineering, AI-native product work, and the systems behind them."
>
  <div class="fade-sequence">
    <header class="collection-header">
      <p class="eyebrow" transition:name="page-kicker">Blog</p>
      <h1 class="page-intro__title" transition:name="page-heading">
        Writing in public about software, product, and systems.
      </h1>
      <p class="page-intro__lede">
        A running set of notes on the decisions, tradeoffs, and tools behind the work. Newest
        entries land first.
      </p>
    </header>

    <div class="content-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</DocsLayout>

<style>
  .collection-header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 2rem;
    max-width: 42rem;
  }
</style>
