---
import { getCollection } from "astro:content";
import DirectoryEntry from "../../components/DirectoryEntry.astro";
import { formatDate } from "../../lib/format-date";
import DocsLayout from "../../layouts/DocsLayout.astro";

const allPosts = await getCollection("blog");
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<DocsLayout
  title="Writing"
  description="Deep dives, post-mortems, and innovation spotlights on software and systems."
>
  <div class="collection">
    <header class="collection__header">
      <p class="eyebrow">Writing</p>
      <h1 class="page-intro__title">Deep dives and post-mortems.</h1>
      <p class="page-intro__lede">
        Longform notes on architecture, tooling, and product systems — written
        in the same documentation format as the project specs.
      </p>
    </header>

    <div class="directory">
      {
        posts.map((post) => (
          <DirectoryEntry
            title={post.data.title}
            href={`/blog/${post.id}`}
            description={post.data.description}
            meta={formatDate(post.data.pubDate)}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </div>
</DocsLayout>

<style>
  .collection__header {
    max-width: 44rem;
    margin-bottom: 2.5rem;
  }
</style>
