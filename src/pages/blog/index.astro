---
import DirectoryEntry from "../../components/DirectoryEntry.astro";
import { formatDate } from "../../lib/format-date";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getSortedPosts } from "../../lib/collections";

const posts = await getSortedPosts();
---

<DocsLayout
  title="Blog"
  description="Deep dives, post-mortems, and innovation spotlights on software and systems."
  showSidebar={false}
>
  <div>
    <header class="max-w-[44rem] mb-10">
      <p class="eyebrow">Blog</p>
      <h1>Deep dives and post-mortems.</h1>
      <p class="lede mt-4">
        Longform notes on architecture, tooling, and product systems — written
        in the same documentation format as the project specs.
      </p>
    </header>

    <div class="flex flex-col border-t border-border">
      {
        posts.map((post) => (
          <DirectoryEntry
            title={post.data.title}
            href={`/blog/${post.id}`}
            description={post.data.description}
            meta={formatDate(post.data.pubDate)}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </div>
</DocsLayout>
