---
import { getCollection } from "astro:content";
import DirectoryEntry from "../components/DirectoryEntry.astro";
import { formatDate } from "../lib/format-date";
import { SITE } from "../consts";
import BaseLayout from "../layouts/BaseLayout.astro";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout title={SITE.title}>
  <div class="home page-stack">
    <header class="page-intro">
      <p class="eyebrow">{SITE.role}</p>
      <h1 class="page-intro__title">Engineering reference.</h1>
      <p class="page-intro__lede">
        Work by {SITE.author}, documented rather than displayed. Each project is
        written up as a technical specification — architecture, stack, and the
        code decisions behind it.
      </p>
    </header>

    <section class="home-section" aria-labelledby="projects-heading">
      <div class="home-section__head">
        <h2 id="projects-heading" class="home-section__title">Projects</h2>
        <a class="text-link text-link--muted" href="/projects">All projects</a>
      </div>

      <div class="directory">
        {
          projects.map((project) => (
            <DirectoryEntry
              title={project.data.title}
              href={`/projects/${project.id}`}
              description={project.data.description}
            />
          ))
        }
      </div>
    </section>

    {
      recentPosts.length > 0 && (
        <section class="home-section" aria-labelledby="writing-heading">
          <div class="home-section__head">
            <h2 id="writing-heading" class="home-section__title">
              Writing
            </h2>
            <a class="text-link text-link--muted" href="/blog">
              All writing
            </a>
          </div>

          <div class="directory">
            {recentPosts.map((post) => (
              <DirectoryEntry
                title={post.data.title}
                href={`/blog/${post.id}`}
                description={post.data.description}
                meta={formatDate(post.data.pubDate)}
              />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>

<style>
  .home {
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  .home-section {
    display: grid;
    gap: 0.5rem;
  }

  .home-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.25rem;
  }

  .home-section__title {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-soft);
  }
</style>
