---
import { getCollection } from "astro:content";
import DirectoryEntry from "../components/DirectoryEntry.astro";
import { formatDate } from "../lib/format-date";
import { SITE } from "../consts";
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusIsland from "../components/StatusIsland.astro";
import StatusFallback from "../components/StatusFallback.astro";

const allProjects = await getCollection("projects");
const projects = allProjects.toSorted((a, b) => a.data.order - b.data.order);

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .toSorted((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout title={SITE.title}>
  <div class="grid gap-[clamp(2.5rem,5vw,4rem)]">
    <header class="max-w-3xl">
      <p class="eyebrow">{SITE.role}</p>
      <h1>Public journal</h1>
      <p class="lede mt-4">Experiments, thoughts, and anything in between.</p>
      <div class="mt-6">
        <StatusIsland server:defer>
          <StatusFallback slot="fallback" />
        </StatusIsland>
      </div>
    </header>

    <section class="grid gap-2" aria-labelledby="projects-heading">
      <div class="flex items-baseline justify-between gap-4 pb-1">
        <h2
          id="projects-heading"
          class="text-[0.78rem] font-semibold tracking-[0.16em] uppercase text-fg-soft"
        >
          Projects
        </h2>
        <a class="text-link text-link--muted" href="/projects">All projects</a>
      </div>

      <div class="flex flex-col border-t border-border">
        {
          projects.map((project) => (
            <DirectoryEntry
              title={project.data.title}
              href={`/projects/${project.id}`}
              description={project.data.description}
            />
          ))
        }
      </div>
    </section>

    {
      recentPosts.length > 0 && (
        <section class="grid gap-2" aria-labelledby="writing-heading">
          <div class="flex items-baseline justify-between gap-4 pb-1">
            <h2
              id="writing-heading"
              class="text-[0.78rem] font-semibold tracking-[0.16em] uppercase text-fg-soft"
            >
              Writing
            </h2>
            <a class="text-link text-link--muted" href="/blog">
              All writing
            </a>
          </div>

          <div class="flex flex-col border-t border-border">
            {recentPosts.map((post) => (
              <DirectoryEntry
                title={post.data.title}
                href={`/blog/${post.id}`}
                description={post.data.description}
                meta={formatDate(post.data.pubDate)}
              />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
