---
import Icon from '../../components/Icon.astro';
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
---

<DocsLayout
  title={project.data.title}
  description={project.data.description}
  headings={headings}
  showToc={true}
>
  <article class="project fade-sequence">
    <header class="project__header">
      <a class="section-link project__back" href="/projects">
        <Icon name="lucide:arrow-right" aria-hidden="true" />
        <span>Back to projects</span>
      </a>

      <p class="eyebrow">Project</p>
      <h1 transition:name={`project-title-${project.id}`}>{project.data.title}</h1>
      <p class="lede">{project.data.description}</p>

      <div class="project__actions">
        {project.data.website && (
          <a href={project.data.website} target="_blank" rel="noopener noreferrer" class="button">
            <span>Visit site</span>
            <Icon name="lucide:arrow-up-right" aria-hidden="true" />
          </a>
        )}
        {project.data.repository && (
          <a
            href={project.data.repository}
            target="_blank"
            rel="noopener noreferrer"
            class="button--ghost"
          >
            <span>Source code</span>
            <Icon name="lucide:arrow-up-right" aria-hidden="true" />
          </a>
        )}
      </div>

      {project.data.tags && project.data.tags.length > 0 && (
        <ul class="tag-list">
          {project.data.tags.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>

<style>
  .project {
    display: grid;
    gap: 2rem;
  }

  .project__header {
    display: grid;
    gap: 0.75rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .project__back {
    width: fit-content;
    color: var(--text-soft);
  }

  .project__back :global(svg) {
    transform: rotate(180deg);
  }

  .project__back:hover,
  .project__back:focus-visible {
    color: var(--accent);
  }

  .project__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
</style>
