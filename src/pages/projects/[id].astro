---
import Icon from "../../components/Icon.astro";
import { getCollection, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
---

<DocsLayout
  title={project.data.title}
  description={project.data.description}
  headings={headings}
  showToc={true}
>
  <article class="grid gap-10">
    <header class="grid gap-[0.85rem] pb-8 border-b border-border">
      <a class="text-link text-link--muted w-fit mb-2 text-[0.85rem]" href="/projects">
        <Icon name="lucide:arrow-right" class="rotate-180" aria-hidden="true" />
        <span>Projects</span>
      </a>

      <p class="eyebrow">Project</p>
      <h1>{project.data.title}</h1>
      <p class="lede">{project.data.description}</p>

      <div class="flex flex-wrap gap-x-6 gap-y-2 mt-2">
        {
          project.data.website && (
            <a
              class="text-link"
              href={project.data.website}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Live site</span>
              <Icon name="lucide:arrow-up-right" aria-hidden="true" />
            </a>
          )
        }
        {
          project.data.repository && (
            <a
              class="text-link"
              href={project.data.repository}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Source code</span>
              <Icon name="lucide:arrow-up-right" aria-hidden="true" />
            </a>
          )
        }
      </div>

      {
        project.data.tags && project.data.tags.length > 0 && (
          <ul class="tag-list">
            {project.data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>
