---
import { getCollection } from "astro:content";
import DirectoryEntry from "../../components/DirectoryEntry.astro";
import DocsLayout from "../../layouts/DocsLayout.astro";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<DocsLayout
  title="Projects"
  description="Selected builds, documented as engineering references by Thiago Moura."
>
  <div class="collection">
    <header class="collection__header">
      <p class="eyebrow">Projects</p>
      <h1 class="page-intro__title">Engineering references.</h1>
      <p class="page-intro__lede">
        Each entry is a technical specification — architecture, stack, and the
        implementation decisions behind the build.
      </p>
    </header>

    <div class="directory">
      {
        projects.map((project) => (
          <DirectoryEntry
            title={project.data.title}
            href={`/projects/${project.id}`}
            description={project.data.description}
            tags={project.data.tags}
          />
        ))
      }
    </div>
  </div>
</DocsLayout>

<style>
  .collection__header {
    max-width: 44rem;
    margin-bottom: 2.5rem;
  }
</style>
