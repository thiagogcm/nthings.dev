---
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ProjectCard.astro';
import DocsLayout from '../../layouts/DocsLayout.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<DocsLayout
  title="Projects"
  description="Selected projects, experiments, and product explorations by Thiago Moura."
>
  <div class="fade-sequence">
    <header class="collection-header">
      <p class="eyebrow" transition:name="page-kicker">Projects</p>
      <h1 class="page-intro__title" transition:name="page-heading">
        Selected builds, experiments, and working systems.
      </h1>
      <p class="page-intro__lede">
        Some are polished, some are exploratory. All of them reflect how I think about product,
        tooling, and practical engineering.
      </p>
    </header>

    <div class="content-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</DocsLayout>

<style>
  .collection-header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 2rem;
    max-width: 42rem;
  }
</style>
