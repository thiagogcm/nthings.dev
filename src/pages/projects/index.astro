---
import DirectoryEntry from "@/components/DirectoryEntry.astro";
import DocsLayout from "@/layouts/DocsLayout.astro";
import { getSortedProjects } from "@/lib/collections";
import { projectActions } from "@/lib/project-actions";

const projects = await getSortedProjects();
const projectCards = projects.map((project) => ({
  project,
  actions: projectActions(project),
}));
---

<DocsLayout
  title="Projects"
  description="Things I build on my spare time."
>
  <div class="project-index">
    <header class="project-index__hero">
      <h1>The things.</h1>
      <p class="lede mt-4">
        This is a collection of pet projects and experiments I build on my spare time. Contributions are welcome.
      </p>
    </header>

    <div class="directory-list directory-list--rich">
      {
        projectCards.map(({ project, actions }) => (
          <DirectoryEntry
            title={project.data.title}
            href={`/projects/${project.id}`}
            description={project.data.description}
            tags={project.data.tags}
            actions={actions}
            variant="rich"
            eyebrow="Reference"
          />
        ))
      }
    </div>
  </div>
</DocsLayout>

<style>
  .directory-list {
    display: flex;
    flex-direction: column;
  }

  .directory-list--rich {
    gap: 0.75rem;
  }

  .project-index {
    display: grid;
    gap: 1.5rem;
  }

  .project-index__hero {
    display: grid;
    gap: 1rem;
    max-width: 54rem;
    margin-bottom: 0.5rem;
  }
</style>
