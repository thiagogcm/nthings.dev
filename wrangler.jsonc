{
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "nthings-dev",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"routes": [
		{
			"pattern": "nthings.dev",
			"zone_name": "nthings.dev",
			"custom_domain": true
		},
		{
			"pattern": "www.nthings.dev",
			"zone_name": "nthings.dev",
			"custom_domain": true
		}
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
